# PyMon NOC Environment Configuration
# Copy this file to .env and customize

# REQUIRED: JWT secret key for token signing (min 32 chars)
# If not set, a persistent secret is auto-generated in .pymon_jwt_secret
JWT_SECRET=change-this-to-a-random-string-at-least-32-chars-long

# Optional: Override config file path
# Default: config.yml
# CONFIG_PATH=/etc/pymon/config.yml

# Optional: CORS allowed origins (comma-separated)
# Default: http://localhost:10000
# PYMON_ALLOWED_ORIGINS=http://localhost:10000,https://monitoring.example.com

# Optional: Database path (overrides config value)
# Default: pymon.db
# DB_PATH=/data/pymon.db

# Optional: Storage backend type
# Default: sqlite
# STORAGE_BACKEND=sqlite

# Optional: Data directory for runtime files
# Default: ./
# DATA_DIR=/var/lib/pymon

# Optional: Log directory
# Default: ./logs
# LOG_DIR=/var/log/pymon

# Optional: TLS certificate and key (for HTTPS)
# Default: disabled (HTTP only)
# TLS_CERT=/etc/pymon/cert.pem
# TLS_KEY=/etc/pymon/key.pem
